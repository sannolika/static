{% extends "layouts/base.njk" %}

LAYOUT TEST: work.njk 🐚

{% block content %}
<article class="work">

  {# HEADER / META #}
  <header class="work-meta">
    <h1>{{ title }}</h1>

    {% if year or medium %}
      <p>
        {% if year %}<strong>{{ year }}</strong>{% endif %}
        {% if medium %}
          {% if year %} · {% endif %}
          {{ medium }}
        {% endif %}
      </p>
    {% endif %}

    {% if summary %}
      <p class="work-summary">{{ summary }}</p>
    {% endif %}
  </header>

  {# HERO: VIDEO OR FIRST IMAGE #}
  {% if video_platform and video_id %}
    <section class="container--wide">
      <div class="work-hero">
        {% if video_platform == "youtube" %}
          <iframe
            src="https://www.youtube.com/embed/{{ video_id }}"
            title="{{ title }}"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            allowfullscreen
            loading="lazy"></iframe>
        {% elif video_platform == "vimeo" %}
          <iframe
            src="https://player.vimeo.com/video/{{ video_id }}"
            title="{{ title }}"
            frameborder="0"
            allow="autoplay; fullscreen; picture-in-picture"
            allowfullscreen
            loading="lazy"></iframe>
        {% endif %}
      </div>
    </section>

  {% elif images and (images | length) %}
    <section class="container--wide">
      <figure class="work-hero">
        <img
          src="{{ images[0] }}"
          alt="{{ images_alt or title }}"
          loading="eager">
      </figure>
    </section>
  {% endif %}

  {# BODY (MARKDOWN CONTENT) #}
  <div class="work-body">
    {{ content | safe }}
  </div>

  {# OPTIONAL IMAGE GALLERY (beyond the hero) #}
  {% if images and (images | length) > 1 %}
    <section class="work-gallery container--wide">
      {% for img in images | slice(1) %}
        <figure class="work-gallery-item">
          <img src="{{ img }}" alt="{{ title }} – image {{ loop.index + 1 }}" loading="lazy">
        </figure>
      {% endfor %}
    </section>
  {% endif %}

  {# CONNECTED PROJECTS #}
  {% if related and (related | length) %}
    <section class="work-related">
      <div class="section-head"><span>Connected projects</span></div>
      <ul>
        {% for slug in related %}
          <li>
            <a href="/works/{{ slug }}/">
              {{ slug | replace("-", " ") | title }}
            </a>
          </li>
        {% endfor %}
      </ul>
    </section>
  {% endif %}

</article>
{% endblock %}
