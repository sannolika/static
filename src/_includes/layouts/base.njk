<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <title>{% if title %}{{ title }} – {{ site.title }}{% else %}{{ site.title }}{% endif %}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Lora:ital,wght@0,400;0,600;1,400;1,600&display=swap" rel="stylesheet">

    <!-- CSS -->
    <link rel="stylesheet" href="/assets/css/styles.css">
  </head>

  <!-- Optional page-wide class comes from front matter: pageClass: "page-wide" -->
  <body class="{{ pageClass or '' }}">

    <header class="site-header">
      <div class="container">
        <a class="brand" href="/">Sanna Fogelvik</a>
        <nav class="primary-nav" aria-label="Primary">
          <a href="/works/">Works</a>
          <a href="/arena/">Research</a>
          <a href="/about/">About</a>
          <a href="/contact/">Contact</a>
        </nav>
      </div>
    </header>

    <main id="content" class="container">
      {{ content | safe }}
    </main>

    <footer class="site-footer">
      <div class="container">
        <p>© {{ site.year }} · {{ site.author }}</p>
      </div>
    </footer>

    <!-- JS (email obfuscation only) -->
    <script src="/assets/js/email.js" defer></script>
  </body>
</html>
