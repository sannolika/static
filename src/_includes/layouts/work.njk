{% extends "layouts/base.njk" %}

{% block content %}
<article class="work">

  <header class="work-meta">
    <h1>{{ title }}</h1>
    <p><strong>{{ year }}</strong>{% if media %} · {{ media }}{% endif %}</p>
  </header>

  {# Hero media (video or first image), widened but centered #}
  {% if video_platform and video_id %}
    <section class="container--wide">
      <div class="work-hero">
        {% if video_platform == "youtube" %}
          <iframe
            src="https://www.youtube.com/embed/{{ video_id }}"
            title="{{ title }}"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            allowfullscreen
            loading="lazy"></iframe>
        {% elif video_platform == "vimeo" %}
          <iframe
            src="https://player.vimeo.com/video/{{ video_id }}"
            title="{{ title }}"
            frameborder="0"
            allow="autoplay; fullscreen; picture-in-picture"
            allowfullscreen
            loading="lazy"></iframe>
        {% endif %}
      </div>
    </section>
  {% elif images and (images | length) %}
    <section class="container--wide">
      <figure class="work-hero">
        <img
          src="{{ images[0] }}"
          alt="{{ images_alt or title }}"
          loading="eager">
      </figure>
    </section>
  {% endif %}

  <div class="work-body">
    {{ content | safe }}
  </div>

  {% if related and (related | length) %}
    <div class="section-head"><span>Connected projects</span></div>
    <ul>
      {% for slug in related %}
        <li><a href="/works/{{ slug }}/">{{ slug | replace("-", " ") | title }}</a></li>
      {% endfor %}
    </ul>
  {% endif %}

</article>
{% endblock %}
